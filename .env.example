# Guesty Open API — OAuth2 client_credentials grant
# Copy to .env locally, and set these as Environment Variables in the Render dashboard.
GUESTY_CLIENT_ID=your-guesty-client-id
GUESTY_CLIENT_SECRET=your-guesty-client-secret

# Admin dashboard credentials
ADMIN_USER=admin
ADMIN_PASS=regent2024

# Truvi host-property damage protection
# Program: "Screening + Protection $0–$1M" preset (full coverage from dollar one).
# Verified list price $31.95/booking at truvi.com/platform/pricing (2026-07).
# NOTE: requires a Truvi account + accepted terms + billing before TRUVI_API_KEY
# can be issued. Until a real key is set, leave TRUVI_ENABLED=false so the worker
# never attempts live enrollment against a non-existent provider.
TRUVI_PLAN_AMOUNT=31.95
TRUVI_PLAN_NAME="Truvi Host Damage Protection ($1M)"
TRUVI_PLAN_COVERAGE_LIMIT=1000000
TRUVI_PLAN_PROGRAM=screening_protection_0_1m
TRUVI_ALLOWED_BOOKING_DOMAINS=bookwithregent.com,regent.guestybookings.com,regent.guestbookings.com
TRUVI_ENABLED=false
TRUVI_API_BASE_URL=https://api.truvi.com
TRUVI_API_KEY=your-truvi-api-key
TRUVI_API_TIMEOUT_MS=12000
TRUVI_API_ENROLL_PATH=/v1/policies
TRUVI_API_UPDATE_PATH=/v1/policies/{policyId}
TRUVI_API_CANCEL_PATH=/v1/policies/{policyId}/cancel
TRUVI_API_REFUND_PATH=/v1/policies/{policyId}/refund
TRUVI_API_FETCH_PATH=/v1/policies/{policyId}
TRUVI_WEBHOOK_SECRET=changeme
TRUVI_WORKER_BATCH_SIZE=10
TRUVI_WORKER_INTERVAL_MS=8000
TRUVI_REQUIRE_CANONICAL_MARKER=true
TRUVI_RETRY_BASE_SECONDS=8
TRUVI_RETRY_MAX_SECONDS=1800
TRUVI_ALLOW_UNCONFIGURED_MOCK=false
TRUVI_MOCK_MODE=false
TRUVI_WORKER_BOOTSTRAP=true
